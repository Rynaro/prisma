# ============================================================================
# .github/review-bot.yml — repo-local configuration for the AI Code Review App
#
# Canonical path: .github/review-bot.yml (in YOUR repo)
# Schema: docs/config-spec.md  (in the App repo)
# Defaults below match the OQ-2 resolutions documented in
#   docs/open-questions.md § OQ-2 — Default values for publication caps and severity floor
# ============================================================================
#
# This is the example/template config for repos that install the prisma App.
# When installed in a repo, the App reads `.github/review-bot.yml` from that
# repo's default branch. The schema is `RepoConfigSchema` in
# `@prisma-bot/shared`; the full key reference lives in `docs/config-spec.md`.

# Master switch. When `false`, the App treats the repo as opted-out: no provider
# call is made and no Checks run is created.
enabled: true

# Publication mode. One of `dry-run`, `summary-only`, `summary-plus-inline`.
# `dry-run` is the default for newly installed repos so maintainers can inspect
# Checks output before the App posts anything PR-visible.
mode: dry-run

# Provider adapter id. The MVP ships Anthropic Claude (per OQ-1); additional
# adapters slot in here without changing pipeline code (per ADR-002).
provider: anthropic

# Optional. Model identifier passed to the provider adapter. Left commented out
# so newcomers do not pin a model id by accident; the adapter selects a
# Claude 4-class model when this key is absent.
# model: claude-4-class-model-id

# Floors applied at the publication-cap stage. `severity_floor.inline` blocks
# `low` and `info` severities from inline comments; `confidence_floor.inline`
# (a number in [0, 1]) gates inline eligibility on the provider's confidence.
thresholds:
  severity_floor:
    inline: medium
  confidence_floor:
    inline: 0.7

# Per-PR and per-file caps on inline comments. Caps protect maintainer trust:
# the App never floods a PR with low-signal advisory noise.
comment_cap:
  per_pr: 5
  per_file: 1

# Path globs that gate which changed files are considered. `include` is
# allow-listed if non-empty; `exclude` removes paths after `include`.
path_rules:
  include: []
  exclude: []

# When `true`, files marked by language-aware "generated" heuristics (lockfiles,
# bundles, autogenerated client code) are skipped before the provider call.
exclude_generated: true

# When `true`, vendored paths (`vendor/`, `third_party/`, etc.) are skipped
# before the provider call.
exclude_vendored: true

# Hard ceiling on the number of changed files in a PR. Beyond this, the
# oversized-diff fast-path bypasses the provider entirely (per
# `docs/data-flow.md` § Flow 2).
max_files: 50

# Hard ceiling on changed lines in a PR. Same fast-path semantics as
# `max_files`; whichever ceiling trips first short-circuits the run.
max_changed_lines: 2000

# Finding categories the App is allowed to surface. The default is the full
# vocabulary; remove categories here to silence them repo-wide.
categories_enabled:
  - security
  - correctness
  - performance
  - tests
  - style
  - migration
  - dependency

# Per-category severity overrides. Map a category to a severity to force the
# App to treat all findings in that category at that severity. Empty by default.
severity: {}

# Per-language overrides. Each key is a language tag (e.g., `typescript`); the
# value is a subset of this top-level config that applies only to files in that
# language. Empty by default.
language_overrides: {}

# Repository-shape heuristics. These bias the prefilter and validator toward
# the named concerns; turn one off to opt out of that concern's heuristics.
repo_heuristics:
  security: true
  tests: true
  migrations: true
  layering: true

# Optional. Mention alias for the bot in PR comments. When set, `@<nickname>`
# is treated as a mention of the bot in addition to the real bot login.
# Must be login-shaped: alphanumeric and hyphens only, no leading hyphen,
# 1–39 characters. Absent → only the real bot login is recognized.
# nickname: ourbot
