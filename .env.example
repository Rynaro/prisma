# Phase 4 scaffold .env.example — placeholder values only.
# Copy to .env and fill in for local development. The scaffold runs without
# real values; secrets are only required once Phase 5 wires the GitHub and
# provider calls.

# --- Server ---
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# --- GitHub App (secret) ---
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=

# --- Provider (secret) ---
# The worker selects a provider by precedence: ANTHROPIC_API_KEY first,
# then COPILOT_API_KEY, otherwise the FakeProvider boot stub. Set exactly
# one of the keys for production-equivalent behavior.
ANTHROPIC_API_KEY=
COPILOT_API_KEY=
# Optional Copilot overrides; sensible defaults baked into the adapter.
COPILOT_MODEL=
COPILOT_BASE_URL=

# --- Queue ---
REDIS_URL=redis://redis:6379

# --- Idempotency / replay protection ---
INSTALLATION_REPLAY_WINDOW_SECONDS=300

# --- Worker tunables ---
QUEUE_CONCURRENCY=4
JOB_TIMEOUT_SECONDS=120

# --- Retry tunables ---
RETRY_TRANSIENT_MAX_ATTEMPTS=3
RETRY_TRANSIENT_BACKOFF_BASE_MS=500
RETRY_TRANSIENT_BACKOFF_MAX_MS=8000
RETRY_RATELIMIT_MAX_ATTEMPTS=5

# --- Cost ceiling ---
MAX_TOKENS_PER_PR=60000
MAX_TOKENS_PER_WINDOW_PER_INSTALLATION=2000000
MAX_TOKENS_WINDOW_SECONDS=3600

# --- OpenTelemetry (optional; leave OTEL_EXPORTER_OTLP_ENDPOINT empty to disable export) ---
OTEL_SERVICE_NAME=prisma-review-bot
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_SAMPLER_ARG=1.0
