# deploy/.env.prod.example — production environment template.
# Consumed by deploy/docker-compose.prod.yml as an env_file AND for
# compose variable interpolation (PRISMA_DOMAIN, IMAGE_TAG, etc.).
# Copy to deploy/.env, fill in secrets, and chmod 600 before deploying.
# The install.sh script performs this substitution interactively.

# --- Deployment ---
# Public domain name for the service (no scheme, no trailing slash).
PRISMA_DOMAIN=
# Email address used for ACME/Let's Encrypt certificate registration.
PRISMA_ACME_EMAIL=
# Docker image tag to deploy. Override at deploy time (e.g. IMAGE_TAG=sha-abc1234).
IMAGE_TAG=latest

# --- Server ---
PORT=3000
LOG_LEVEL=info

# --- GitHub App (secret) ---
GITHUB_APP_ID=
GITHUB_APP_SLUG=
# PEM private key contents, single-line with literal \n escapes.
# The env-file format requires single-line values; install.sh encodes the
# .pem file accordingly. The SecretSource implementation reads process env.
GITHUB_APP_PRIVATE_KEY=
# HMAC webhook secret — generated by install.sh via openssl rand -hex 32.
# Paste this value into the GitHub App registration webhook secret field.
GITHUB_APP_WEBHOOK_SECRET=

# --- Provider (secret) ---
# The worker selects a provider by precedence:
#   ANTHROPIC_API_KEY → COPILOT_API_KEY → OPENAI_API_KEY → FakeProvider
# Set exactly one of the keys for production-equivalent behavior.
ANTHROPIC_API_KEY=
COPILOT_API_KEY=
# Optional Copilot overrides; sensible defaults baked into the adapter.
COPILOT_MODEL=
COPILOT_BASE_URL=
OPENAI_API_KEY=
# Optional OpenAI overrides; sensible defaults baked into the adapter.
OPENAI_MODEL=
OPENAI_BASE_URL=

# --- Queue ---
# Note: compose overrides REDIS_URL for the internal Docker network.
# This value is used by processes connecting from outside the compose network.
REDIS_URL=redis://redis:6379

# --- Idempotency / replay protection ---
INSTALLATION_REPLAY_WINDOW_SECONDS=300

# --- OpenTelemetry (optional; leave OTEL_EXPORTER_OTLP_ENDPOINT empty to disable export) ---
OTEL_SERVICE_NAME=prisma-review-bot
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Worker tunables ---
QUEUE_CONCURRENCY=4
JOB_TIMEOUT_SECONDS=120

# --- Retry tunables ---
RETRY_TRANSIENT_MAX_ATTEMPTS=3
RETRY_TRANSIENT_BACKOFF_BASE_MS=500
RETRY_TRANSIENT_BACKOFF_MAX_MS=8000
RETRY_RATELIMIT_MAX_ATTEMPTS=5

# --- Cost ceiling ---
MAX_TOKENS_PER_PR=60000
MAX_TOKENS_PER_WINDOW_PER_INSTALLATION=2000000
MAX_TOKENS_WINDOW_SECONDS=3600

# --- Sampling ---
OTEL_TRACES_SAMPLER_ARG=1.0
