node-linker=hoisted
link-workspace-packages=true
shared-workspace-lockfile=true
strict-peer-dependencies=false
auto-install-peers=true
# Pin the pnpm content-addressable store onto the same Docker-volume
# backend as /app/node_modules so hardlink population works regardless of
# host UID. Without this, pnpm falls back to /app/.pnpm-store (under the
# bind-mounted host workspace, on a different device from the named
# node_modules volume) and EXDEVs on every hardlink. The dev Dockerfile
# pre-creates /pnpm/store and chmods it 0777; compose mounts the
# `pnpm_store` named volume at that path. The setting is harmless on a
# host pnpm install (the project is container-only per README § Setup).
store-dir=/pnpm/store
